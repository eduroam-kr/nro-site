---
layout: none
---
[
  {% assign pages = site.pages | concat: site.notices %}
  {% for page in pages %}
    {% if page.title and page.url != "/search.json" %}
    {
      "title": "{{ page.title | escape }}",
      "url": "{{ page.url | relative_url }}",
      "content": "{{ page.content | strip_html | strip_newlines | escape | truncatewords: 50 }}"
    }{% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
]
